rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, update: if request.auth.uid == userId;

      match /entries/{entryId} {
        allow read, create, delete: if request.auth.uid == userId;
      }

      match /essays/{essayId} {
        allow read, create, delete: if request.auth.uid == userId;
      }
    }
  }
}
