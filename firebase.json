{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "storage.rules",
      "**/node_modules/**",
      "**/.*"
    ],
    "rewrites": [
      {
        "source": "/generate-essay",
        "function": "generateEssay"
      }
    ]
  }
}
